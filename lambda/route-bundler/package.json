{
  "name": "flightlevel-route-bundler",
  "version": "1.0.0",
  "description": "Nightly route bundle assembler for FlightLevel",
  "type": "module",
  "main": "index.mjs",
  "scripts": {
    "package": "npm ci --omit=dev && zip -r ../route-bundler.zip . -x '*.zip'",
    "invoke-local": "node -e \"import('./index.mjs').then(m => m.handler({}).then(console.log))\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1040.0",
    "@supabase/supabase-js": "2.105.1"
  }
}
